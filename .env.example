# MediMap AI — Project Configuration
# Copy this file to .env and fill in your keys

# ── Application ───────────────────────────────────────────────────────────────
APP_TITLE=MediMap AI
APP_VERSION=1.0.0
DEBUG=True

# ── GIS / Maps ────────────────────────────────────────────────────────────────
# Default search radius for specialist search (metres)
GEO_SEARCH_RADIUS_M=10000
# Maximum clinics returned in results
GEO_MAX_RESULTS=10
# Overpass API endpoint (public mirror; swap if rate-limited)
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# Nominatim user-agent (required by OSM ToS — put your app name)
NOMINATIM_USER_AGENT=medimap_ai_v1

# ── Model Paths ───────────────────────────────────────────────────────────────
TABULAR_MODEL_PATH=models/saved/tabular_mlp.pth
VISION_MODEL_PATH=models/saved/vision_cnn.pth
FUSION_MODEL_PATH=models/saved/fusion_head.pth
LABEL_ENCODER_PATH=models/saved/label_encoder.pkl
SYMPTOM_COLUMNS_PATH=data/processed/symptom_columns.json

# ── CUDA ──────────────────────────────────────────────────────────────────────
# Force CPU even if GPU is available (set to 1 for CPU-only mode)
FORCE_CPU=0

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=medimap_hybrid_fusion
